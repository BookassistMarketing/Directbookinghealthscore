# Environment variables for Direct Booking Health Score
#
# GEMINI_API_KEY is server-only — never exposed to the browser.
# Must be set locally in .env (gitignored) and in the Amplify console
# under App settings → Environment variables.
#
# NOTE: the old NEXT_PUBLIC_GEMINI_API_KEY variable is deprecated.
# Delete it from Amplify after setting GEMINI_API_KEY.
GEMINI_API_KEY=
