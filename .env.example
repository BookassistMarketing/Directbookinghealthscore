# Environment variables for Direct Booking Health Score
#
# Copy this file to .env.local (gitignored) and fill in the value.
# Next.js automatically loads .env.local for `npm run dev` and `npm run build`.
#
# In production (AWS Amplify): set GEMINI_API_KEY in
#   App settings → Environment variables
# and remove the deprecated NEXT_PUBLIC_GEMINI_API_KEY entry.
#
# GEMINI_API_KEY is server-only — NEVER prefix with NEXT_PUBLIC_.
# The only code path that reads it is app/api/*/route.ts, which runs
# on the Node.js runtime and is never bundled for the browser.
GEMINI_API_KEY=

# Staff bypass (hidden /staff page). Server-only. Never NEXT_PUBLIC_.
# STAFF_PASSWORD: shared password for general staff (sales, ops). Grants
# lead-capture bypass on both audits.
# STAFF_MARKETING_PASSWORD: shared password for marketing only. Grants
# everything STAFF_PASSWORD does, PLUS access to the "preview end page
# with sample report" shortcut on the AI Visibility Audit (skips Gemini).
# Different password so a sales rep using STAFF_PASSWORD during a live
# prospect demo can never accidentally show a fake report.
# STAFF_TOKEN_SECRET: HMAC signing secret for the 30-day session token.
# Generate once with: openssl rand -hex 32
STAFF_PASSWORD=
STAFF_MARKETING_PASSWORD=
STAFF_TOKEN_SECRET=

# AUDIT_RATE_LIMIT_SECRET: HMAC signing secret for the audit-throttle cookie.
# Required in production. Generate with: openssl rand -hex 32
AUDIT_RATE_LIMIT_SECRET=
